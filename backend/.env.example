PORT=5000

# Your personal encryption key (min 32 chars) - NEVER share this
ENCRYPTION_KEY=your-super-secret-encryption-key-min-32-chars!!

# JWT secret for session tokens
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Admin panel 6-digit PIN (default is 000000 — change this!)
ADMIN_PIN=123456

# Google Sheets - create a service account and share your sheet with its email
GOOGLE_SHEETS_ID=your-google-sheet-id-from-url
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gmail SMTP for OTP emails (use App Password for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kollurukv@gmail.com
SMTP_PASS=your-gmail-app-password

# Owner email for OTP delivery
OWNER_EMAIL=kollurukv@gmail.com

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
